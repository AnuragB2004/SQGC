    box(ax, 1.5, 3.8, 2.2, 0.7, 'Game Strategy\nModule $U(\\theta_A)$', '#fff3e0', '#e65100', 8)
    box(ax, 1.5, 2.6, 2.2, 0.7, 'Nash Equilibrium\nSolver', '#fff9c4', '#f57f17', 8)
    box(ax, 1.5, 1.4, 2.2, 0.7, 'Privacy\nAmplification', '#fce4ec', '#880e4f', 8)

