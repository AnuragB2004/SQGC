    box(ax, 11.5, 3.8, 2.2, 0.7, 'Game Strategy\nModule $U(\\theta_B)$', '#fff3e0', '#e65100', 8)
    box(ax, 11.5, 2.6, 2.2, 0.7, 'Nash Equilibrium\nSolver', '#fff9c4', '#f57f17', 8)
    box(ax, 11.5, 1.4, 2.2, 0.7, 'Error\nCorrection', '#fce4ec', '#880e4f', 8)

    # Quantum channel
